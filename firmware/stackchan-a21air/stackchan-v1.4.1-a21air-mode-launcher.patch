+#pragma once
+#include <mooncake.h>
+#include <smooth_lvgl.hpp>
+#include <uitk/short_namespace.hpp>
+#include <memory>
+#include <string>
+#include <vector>
+
+class AppA21Mode : public mooncake::AppAbility {
+public:
+    AppA21Mode();
+
+    void onCreate() override;
+    void onOpen() override;
+    void onRunning() override;
+    void onClose() override;
+
+private:
+    struct ModeStatus {
+        std::string activeMode;
+        std::string requestedMode;
+        bool override = false;
+        bool available = false;
+        std::string reason;
+        std::string error;
+    };
+
+    std::unique_ptr<uitk::lvgl_cpp::Container> _panel;
+    std::unique_ptr<uitk::lvgl_cpp::Label> _title;
+    std::unique_ptr<uitk::lvgl_cpp::Label> _status_label;
+    std::unique_ptr<uitk::lvgl_cpp::Label> _hint_label;
+    std::vector<std::unique_ptr<uitk::lvgl_cpp::Button>> _mode_buttons;
+    std::unique_ptr<uitk::lvgl_cpp::Button> _refresh_button;
+    std::string _active_mode = "casual";
+    bool _active_available = true;
+    std::string _active_reason = "available";
+    bool _pending_refresh = false;
+    std::string _pending_select;
+    bool _busy = false;
+
+    void build_ui();
+    void update_status_text(const std::string& text, uint32_t color);
+    void apply_status(const ModeStatus& status);
+    void refresh_status();
+    void select_mode(const std::string& mode);
+    ModeStatus request_mode_status();
+    ModeStatus request_select_mode(const std::string& mode);
+    ModeStatus request_device_mode(const std::string& method, const std::string& endpoint, const std::string& body);
+    std::string gateway_url(const std::string& endpoint);
+    std::string websocket_auth_header();
+    void style_mode_buttons();
+};
