+#if CONFIG_A21_AIR_KEEP_WEBSOCKET_CONNECTED
+void Application::ScheduleWebsocketReconnect(int delay_ms) {
+    if (websocket_reconnect_timer_handle_ == nullptr || !network_connected_ || protocol_ == nullptr) {
+        return;
+    }
+    if (delay_ms < 1000) {
+        delay_ms = 1000;
+    }
+    esp_timer_stop(websocket_reconnect_timer_handle_);
+    esp_timer_start_once(websocket_reconnect_timer_handle_, (uint64_t)delay_ms * 1000);
+}
+
+void Application::CancelWebsocketReconnect() {
+    if (websocket_reconnect_timer_handle_ != nullptr) {
+        esp_timer_stop(websocket_reconnect_timer_handle_);
+    }
+}
+
+void Application::HandleWebsocketReconnectEvent() {
+    if (!network_connected_ || protocol_ == nullptr) {
+        return;
+    }
+
+    if (protocol_->IsAudioChannelOpened()) {
+        ScheduleWebsocketReconnect(CONFIG_A21_AIR_WEBSOCKET_RECONNECT_INTERVAL_MS);
+        return;
+    }
+
+    if (GetDeviceState() != kDeviceStateIdle) {
+        ScheduleWebsocketReconnect(CONFIG_A21_AIR_WEBSOCKET_RECONNECT_INTERVAL_MS);
+        return;
+    }
+
+    ESP_LOGI(TAG, "Opening A21 Air hot Xiaozhi websocket");
+    SetDeviceState(kDeviceStateConnecting);
+    bool opened = protocol_->OpenAudioChannel();
+    if (opened) {
+        ESP_LOGI(TAG, "A21 Air hot Xiaozhi websocket connected");
+    } else {
+        ESP_LOGW(TAG, "A21 Air hot Xiaozhi websocket reconnect failed; retrying");
+    }
+
+    SetDeviceState(kDeviceStateIdle);
+    if (!opened) {
+        if (protocol_) {
+            protocol_->CloseAudioChannel(false);
+        }
+        ScheduleWebsocketReconnect(CONFIG_A21_AIR_WEBSOCKET_RECONNECT_INTERVAL_MS);
+    } else {
+        ScheduleWebsocketReconnect(CONFIG_A21_AIR_WEBSOCKET_RECONNECT_INTERVAL_MS);
+    }
+}
+#endif
+
