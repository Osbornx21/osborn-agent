@@ -734,0 +735,18 @@ config SEND_WAKE_WORD_DATA
+config A21_AIR_KEEP_WEBSOCKET_CONNECTED
+    bool "A21 Air: keep Xiaozhi WebSocket connected while idle"
+    default n
+    depends on BOARD_TYPE_M5STACK_STACK_CHAN
+    help
+        Open and maintain the Xiaozhi WebSocket audio channel in the background
+        while the device is idle. This only sends the protocol hello and keeps
+        the cloud session warm; it does not start listening or upload microphone
+        audio until the normal Xiaozhi wake/touch listening path runs.
+
+config A21_AIR_WEBSOCKET_RECONNECT_INTERVAL_MS
+    int "A21 Air Xiaozhi WebSocket reconnect interval (ms)"
+    default 5000
+    range 1000 60000
+    depends on A21_AIR_KEEP_WEBSOCKET_CONNECTED
+    help
+        Retry interval for the A21 Air idle hot WebSocket reconnect loop.
+
